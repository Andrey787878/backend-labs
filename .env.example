# Параметры PostgreSQL
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Параметры запуска приложения
APP_HOST=0.0.0.0
APP_PORT=8080

# JWT_SECRET используется для подписи JWT access и refresh token
JWT_SECRET=replace_with_min_32_chars_jwt_secret_value
JWT_ALGORITHM=HS256
# REFRESH_TOKEN_PEPPER используется только для хеширования refresh token
REFRESH_TOKEN_PEPPER=replace_with_min_16_chars_pepper

# Время жизни токенов в минутах
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_MINUTES=10080

# Лимит одновременно активных сессий пользователя
MAX_ACTIVE_SESSIONS=5
