# Параметры PostgreSQL
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Параметры запуска приложения
APP_HOST=0.0.0.0
APP_PORT=8080

# JWT_SECRET используется для подписи JWT access и refresh token
JWT_SECRET=replace_with_min_32_chars_jwt_secret_value
JWT_ALGORITHM=HS256
# REFRESH_TOKEN_PEPPER используется только для хеширования refresh token
REFRESH_TOKEN_PEPPER=replace_with_min_16_chars_pepper

# Время жизни токенов в минутах
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_MINUTES=10080

# Лимит одновременно активных сессий пользователя
MAX_ACTIVE_SESSIONS=5

# ЛР6: Git webhook deployment
GIT_WEBHOOK_SECRET=00000000-0000-0000-0000-000000000000
GIT_DEFAULT_BRANCH=main
GIT_WEBHOOK_LOCK_TTL_SECONDS=300
GIT_WEBHOOK_COMMAND_TIMEOUT_SECONDS=120

# ЛР7: Request/Response logging
REQUEST_LOG_RETENTION_HOURS=73
REQUEST_LOG_BODY_MAX_CHARS=20000
REQUEST_LOG_CLEAN_INTERVAL_SECONDS=3600

# ЛР8: queued analytics reports
REPORT_TIME_INTERVAL_HOURS=24
REPORT_JOB_TIMEOUT_MINUTES=5
REPORT_JOB_RETRY_DELAY_MINUTES=2
REPORT_JOB_MAX_ATTEMPTS=3
REPORT_ADMIN_EMAIL=admin@example.com
REPORT_WORKER_POLL_INTERVAL_SECONDS=5
REPORTS_DIR=reports
