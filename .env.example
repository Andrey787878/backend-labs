# Параметры PostgreSQL
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Параметры запуска приложения
APP_HOST=0.0.0.0
APP_PORT=8080

# JWT_SECRET используется только для подписи JWT access token
JWT_SECRET=change_me
JWT_ALGORITHM=HS256
# REFRESH_TOKEN_PEPPER используется только для хеширования refresh token
REFRESH_TOKEN_PEPPER=change_me

# Время жизни токенов в минутах
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_MINUTES=10080

# Лимит одновременно активных сессий пользователя
MAX_ACTIVE_SESSIONS=5

# Базовый rate limit для auth-эндпоинтов (защита от brute-force)
LOGIN_RATE_LIMIT_MAX_REQUESTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
REFRESH_RATE_LIMIT_MAX_REQUESTS=10
REFRESH_RATE_LIMIT_WINDOW_SECONDS=60
